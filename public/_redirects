# Netlify redirects — supplemental to netlify.toml
# netlify.toml takes precedence; rules here are a safety fallback only.

# Strip legacy hash-bang and hash routes → clean paths
/#!/*  /:splat  301!
/#/*   /:splat  301!

# Pass Netlify function calls through
/.netlify/functions/*  /.netlify/functions/:splat  200

# SPA fallback — serves index.html for any path not matched above or in netlify.toml
/*  /index.html  200
